# Twitter/X RapidAPI 配置
RAPIDAPI_KEY=your_rapidapi_key_here

# 兼容旧 Twitter API 配置（当前主流程不依赖，可留空）
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Telegram Bot 配置
# 创建机器人: 联系 @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 获取群组ID: 将机器人添加到群组，发送消息，然后访问 https://api.telegram.org/bot<YourBOTToken>/getUpdates
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# 管理员Chat ID: 用于接收私信转发、黑名单通知、广告警报等
ADMIN_CHAT_ID=your_admin_chat_id_here
# 管理员 User ID allowlist: 用于校验管理命令权限，多个 ID 用英文逗号分隔
ADMIN_USER_IDS=your_admin_user_id_here

# 监控配置
TWITTER_USERNAME=xiuchiluchu910
CHECK_INTERVAL=28800
ALLOWED_USERNAMES=mteacherlu,bryansuperb

# 数据库配置
DATABASE_PATH=tweets.db
